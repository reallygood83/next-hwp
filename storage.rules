rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /briefings/{userId}/{shareId}/{fileName} {
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('text/html.*|audio/.*|application/zip');

      allow read: if true;
    }
  }
}
