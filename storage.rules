rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /briefings/{userId}/{shareId}/{fileName} {
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size <= 15 * 1024 * 1024
        && (
          request.resource.contentType.matches('audio/.*')
          || request.resource.contentType == 'application/pdf'
          || request.resource.contentType == 'text/html'
          || request.resource.contentType == 'application/x-hwp'
          || request.resource.contentType == 'application/haansofthwp'
          || request.resource.contentType == 'application/vnd.hancom.hwpx'
          || request.resource.contentType == 'application/octet-stream'
        );

      allow delete: if request.auth != null
        && request.auth.uid == userId;

      allow read: if true;
    }
  }
}
